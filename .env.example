# ──────────────────────────────────────────────────────────────────────────────
# Oxphyre — Plantilla de variables de entorno
#
# Copia este archivo a .env y rellena los valores reales.
# El archivo .env está en .gitignore y NUNCA debe subirse a GitHub.
# Cada desarrollador o servidor tiene su propio .env con sus credenciales.
# ──────────────────────────────────────────────────────────────────────────────


# ─── Base de datos MySQL ───────────────────────────────────────────────────────
# Servidor donde corre MySQL. En producción es localhost (mismo servidor).
DB_HOST=localhost
DB_PORT=3306
# Nombre de la base de datos. En producción: oxphyre
DB_NAME=oxphyre
# Usuario MySQL con permisos solo sobre esta BD. Nunca usar root en producción.
DB_USER=oxphyre
DB_PASS=


# ─── Aplicación ───────────────────────────────────────────────────────────────
APP_NAME=Oxphyre
# URL base sin slash final. En local: http://localhost. En producción: https://oxphyre.com
APP_URL=https://oxphyre.com
# Clave secreta aleatoria de 64 caracteres hexadecimales.
# Úsala para firmar tokens CSRF y otras operaciones criptográficas.
# Genera una nueva con: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=
# Entorno de ejecución: 'production' muestra errores genéricos al usuario.
# 'development' muestra errores detallados en pantalla. Nunca 'development' en producción.
APP_ENV=production


# ─── Correo (PHPMailer + Gmail SMTP) ──────────────────────────────────────────
# Configuración para el envío de emails transaccionales:
# verificación de cuenta, recuperación de contraseña, notificaciones.
MAIL_HOST=smtp.gmail.com
# Puerto 587 con STARTTLS (recomendado). Alternativa: 465 con SSL.
MAIL_PORT=587
# Cuenta de Gmail desde la que se envían los emails.
MAIL_USER=
# Contraseña de aplicación de Gmail (no la contraseña normal de la cuenta).
# Generar en: Cuenta de Google → Seguridad → Contraseñas de aplicaciones
MAIL_PASS=
# Dirección From que verá el destinatario.
MAIL_FROM=noreply@oxphyre.com
MAIL_FROM_NAME=Oxphyre


# ─── Microservicio Python (Flask + MiDaS) ─────────────────────────────────────
# URL interna del servicio Flask que procesa imágenes con MiDaS.
# En producción usar 127.0.0.1 — el servicio NO debe ser accesible desde el exterior.
PYTHON_SERVICE_URL=http://127.0.0.1:5000
# Clave compartida para autenticar peticiones PHP → Python.
# El servicio Flask valida este header antes de procesar cualquier imagen.
# Genera una nueva con: python3 -c "import secrets; print(secrets.token_hex(32))"
PYTHON_SERVICE_KEY=
