# ──────────────────────────────────────────────────────────────────────────────
# Oxphyre — Plantilla de variables de entorno
#
# Copia este archivo a .env y rellena los valores reales.
# El archivo .env está en .gitignore y NUNCA debe subirse a GitHub.
# Cada desarrollador o servidor tiene su propio .env con sus credenciales.
# ──────────────────────────────────────────────────────────────────────────────


# ─── Base de datos MySQL ───────────────────────────────────────────────────────
# Servidor donde corre MySQL. En producción es localhost (mismo servidor).
DB_HOST=localhost
DB_PORT=3306
# Nombre de la base de datos. En producción: oxphyre
DB_NAME=oxphyre
# Usuario MySQL con permisos solo sobre esta BD. Nunca usar root en producción.
DB_USER=oxphyre
DB_PASS=


# ─── Aplicación ───────────────────────────────────────────────────────────────
APP_NAME=Oxphyre
# URL base sin slash final. En local: http://localhost. En producción: https://oxphyre.com
APP_URL=https://oxphyre.com
# Clave secreta aleatoria de 64 caracteres hexadecimales.
# Úsala para firmar tokens CSRF y otras operaciones criptográficas.
# Genera una nueva con: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=
# Salt privado para pseudonimizar IPs en analitica QR con hash_hmac().
# Produccion debe definir un valor aleatorio propio. No subir el valor real.
QR_HASH_SALT=
# Entorno de ejecución: 'production' muestra errores genéricos al usuario.
# 'development' muestra errores detallados en pantalla. Nunca 'development' en producción.
APP_ENV=production


# ─── Correo (PHPMailer + Gmail SMTP) ──────────────────────────────────────────
# Configuración para el envío de emails transaccionales:
# verificación de cuenta, recuperación de contraseña, notificaciones.
MAIL_HOST=smtp.gmail.com
# Puerto 587 con STARTTLS (recomendado). Alternativa: 465 con SSL.
MAIL_PORT=587
# Cuenta de Gmail desde la que se envían los emails.
MAIL_USER=
# Contraseña de aplicación de Gmail (no la contraseña normal de la cuenta).
# Generar en: Cuenta de Google → Seguridad → Contraseñas de aplicaciones
MAIL_PASS=
# Dirección From que verá el destinatario.
MAIL_FROM=noreply@oxphyre.com
MAIL_FROM_NAME=Oxphyre

# Destinatario de los mensajes enviados desde /contacto.
# Cloudflare Email Routing reenvía support@oxphyre.com al buzón real.
# Cambiar si se usa otro alias o se migra a un servicio transaccional.
CONTACT_TO_EMAIL=support@oxphyre.com
CONTACT_TO_NAME="Oxphyre Support"


# ─── Microservicio Python (Flask + MiDaS) ─────────────────────────────────────
# URL interna del servicio Flask que procesa imágenes con MiDaS.
# En producción usar 127.0.0.1 — el servicio NO debe ser accesible desde el exterior.
PYTHON_SERVICE_URL=http://127.0.0.1:5000
# Clave compartida para autenticar peticiones PHP → Python.
# El servicio Flask valida este header antes de procesar cualquier imagen.
# Genera una nueva con: python3 -c "import secrets; print(secrets.token_hex(32))"
PYTHON_SERVICE_KEY=


# ─── Cloudflare R2 (almacenamiento WebP finales) ─────────────────────────────
# R2_ENABLED controla si Oxphyre intenta subir los WebP finales visibles a R2.
# En desarrollo puede estar en false. En producción solo poner true cuando R2 esté probado.
R2_ENABLED=false

# Account ID de Cloudflare. No es el email ni el nombre de cuenta.
R2_ACCOUNT_ID=

# Credenciales R2 con permisos mínimos sobre el bucket oxphyre-tour-media.
# Nunca subir valores reales a GitHub.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket separado para fotos reales de tours. No usar oxphyre-assets.
R2_BUCKET=oxphyre-tour-media

# Endpoint S3-compatible de Cloudflare R2.
# Formato: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# URL pública base del custom domain conectado al bucket.
# Se concatena con storage_key para formar la public_url final.
R2_PUBLIC_BASE_URL=https://media.oxphyre.com

# Región usada por R2 para firma S3-compatible.
R2_REGION=auto

# Salt privado para pseudonimizar IPs en analítica QR.
# Se usa para generar ip_hash sin guardar la IP real del visitante.
# Genera un valor único en producción con: php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
QR_HASH_SALT=valor_generado_aqui